/**
Time Complexity: O(m × n) because every cell is visited at most once.
Auxiliary Space: O(m × n) in the worst case if the entire image is one connected component, because the recursion stack can grow to the number of visited cells. If the connected region is smaller, the recursion depth is smaller. */

class Solution {
    int[][] directions = { { 1, 0 }, { 0, 1 }, { -1, 0 }, { 0, -1 } };
    int original_color;

    public int[][] floodFill(int[][] image, int sr, int sc, int color) {
        original_color = image[sr][sc];
        if (image[sr][sc] != color)
            dfs(image, sr, sc, color);
        return image;
    }

    private void dfs(int[][] image, int r, int c, int color) {
        //base condition
        if (r < 0 || c < 0 || r == image.length || c == image[0].length)
            return;
        if (image[r][c] != original_color)
            return;
        //logic
        image[r][c] = color;

        //navigation
        dfs(image, r + 1, c + 0, color);
        dfs(image, r + 0, c + 1, color);
        dfs(image, r - 1, c + 0, color);
        dfs(image, r + 0, c - 1, color);
        //or
        /**
        for (int[] dir : directions) {
            dfs(image, r + dir[0], c + dir[1], color);
        }
        
         */

    }
}
