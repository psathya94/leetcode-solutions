//TC - O(n)
//SC-O(1)
class Solution {
    public List<Integer> findDisappearedNumbers(int[] nums) {
        List<Integer> output = new ArrayList<Integer>();
        for(int n:nums){
            int idx = Math.abs(n) -1;
            if(nums[idx]>0){
                nums[idx] =-nums[idx] ;
            }
        }
        for(int i=0;i<nums.length;i++){
            if(nums[i]>0){
                output.add(i+1);
            }
        }
        return output;
    }
}
