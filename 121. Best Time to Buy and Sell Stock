//TC - O(n)
//SC-O(1)
class Solution {
    public int maxProfit(int[] prices) {
        int buy = prices[0];
        int maxProfit = 0;
        int currentProfit = 0;
        for(int i=1; i<prices.length; i++){
            currentProfit = prices[i] - buy;
            maxProfit = Math.max(maxProfit, currentProfit);
            buy = Math.min(buy,prices[i]);
        }
        return maxProfit;
    }
}
