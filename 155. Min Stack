//Time Complexity: push(), pop(), top(), and getMin() all run in O(1) time because they perform a constant number of stack operations.

//Auxiliary Space per operation = O(1)
//Space Complexity: O(n), where n is the number of elements in the stack. The main stack stores all elements, and in the worst case (when elements are pushed in decreasing order), the minStack also stores all elements.
class MinStack {
    private Stack<Integer> stack;
    private Stack<Integer> minStack;

    public MinStack() {
        this.stack = new Stack<>();
        this.minStack = new Stack<>();
        minStack.push(Integer.MAX_VALUE);
    }

    public void push(int value) {
        if (value <= minStack.peek()) 
            minStack.push(value);
        stack.push(value);
    }

    public void pop() {
        int popped = stack.pop();
        if (minStack.peek() == popped){
            minStack.pop();
        }
            
    }

    public int top() {
        return stack.peek();
    }

    public int getMin() {
        return minStack.peek();
    }
}

