//TC-O(m*n)
//SC-O(1)
class Solution {
    public void gameOfLife(int[][] board) {
        int[][] directions = {
                { -1, 0 }, // 1. Up
                { -1, 1 }, // 2. Up-Right
                { 0, 1 }, // 3. Right
                { 1, 1 }, // 4. Down-Right
                { 1, 0 }, // 5. Down
                { 1, -1 }, // 6. Down-Left
                { 0, -1 }, // 7. Left
                { -1, -1 } // 8. Up-Left
        };
        int r = board.length;
        int c = board[0].length;
        for (int i = 0; i < r; i++) {
            for (int j = 0; j < c; j++) {
                int aliveCount = 0;
                for (int[] dir : directions) {
                    int row = i + dir[0];
                    int col = j + dir[1];
                    if (row < 0 || col < 0 || row >= r || col >= c) {
                        continue;
                    }
                    if (Math.abs(board[row][col]) == 1) {
                        aliveCount++;
                    }
                }
                if (board[i][j] == 1 && (aliveCount < 2 || aliveCount > 3)) {
                    board[i][j] = -1; //live to dead
                } else if (board[i][j] == 0 && aliveCount == 3) {
                    board[i][j] = -2;//dead to live
                }

            }
        }
        for (int i = 0; i < r; i++) {
            for (int j = 0; j < c; j++) {
                if(board[i][j]==-1)
                    board[i][j] = 0;
                else if(board[i][j]==-2)
                board[i][j] = 1;
            }
        }
    }
}
